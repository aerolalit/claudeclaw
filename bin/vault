#!/usr/bin/env bash
# bin/vault — claudeclaw memory CLI (option-A: ripgrep + index.md)
#
# Subcommands:
#   vault search <query>            keyword search (BM25 via rg, no semantic)
#   vault read <path>               print a note (path relative to $VAULT_PATH)
#   vault write <path>              write stdin to a note (creates parents)
#   vault daily [today|YYYY-MM-DD]  open / create a daily note
#   vault daily-append <text>       append a line to today's daily note
#   vault backlinks <name>          files that contain [[name]]
#   vault index                     regenerate index.md (Karpathy-style catalog)
#   vault ls [path]                 list .md files
#   vault log "<line>"              append timestamped line to vault/log.md
#   vault scaffold                  ensure Karpathy layout exists (raw/, wiki/people, etc.)
#
# Roadmap (not in v1): tag/tags (need real YAML parser), project queries,
# generic frontmatter queries, SQLite FTS5 backend with temporal decay.
#
# Vault location: $VAULT_PATH (from environment / .env). Default: ./vault/
# Output: tries to be JSON-shaped where useful for agent consumption.
#
# Dependencies: rg (ripgrep), yq (frontmatter parsing — only for `index`/`tags`)

set -uo pipefail

# --- Resolve vault path ---
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
VAULT_PATH="${VAULT_PATH:-$REPO_ROOT/vault}"

# Bypass the existence check for `scaffold` — its whole job is to create the dir.
if [ ! -d "$VAULT_PATH" ] && [ "${1:-}" != "scaffold" ]; then
  echo "ERROR: vault not found at $VAULT_PATH" >&2
  echo "  Run 'bin/vault scaffold' to create it, or set VAULT_PATH in .env." >&2
  exit 1
fi

# --- Tool availability ---
# Use `type -P` to find the actual binary, bypassing shell functions/aliases.
# (Some environments — e.g. Claude Code — wrap rg/grep with shell functions.)
need() {
  local bin
  bin=$(type -P "$1" 2>/dev/null)
  if [ -z "$bin" ]; then
    echo "ERROR: '$1' not found on PATH." >&2
    case "$1" in
      rg) echo "  Install ripgrep: brew install ripgrep | apt install ripgrep" >&2 ;;
      yq) echo "  Install yq: brew install yq | apt install yq" >&2 ;;
    esac
    exit 1
  fi
  # Replace rg/yq calls with the real binary path via a function.
  eval "${1}() { '$bin' \"\$@\"; }"
}

# Resolve a possibly-bare wikilink target to a relative path inside the vault.
# Strategy: case-insensitive, normalize space/-/_ to a regex class. Returns
# the first match (shortest unique path).
resolve_wikilink() {
  local name="$1"
  # strip optional .md
  name="${name%.md}"
  # build a regex that treats space/-/_ as equivalent
  local pat
  pat=$(echo "$name" | sed 's/[ _-]/[ _-]/g')
  rg --files -t md "$VAULT_PATH" 2>/dev/null \
    | rg -i "(^|/)${pat}\.md$" \
    | awk '{ print length($0), $0 }' \
    | sort -n \
    | head -1 \
    | cut -d' ' -f2-
}

cmd_search() {
  need rg
  local q="$1"
  if [ -z "$q" ]; then
    echo "usage: vault search <query>" >&2
    exit 2
  fi
  # Heading + body. Show file:line and a snippet, JSON output.
  rg --json -i -t md --max-count 5 "$q" "$VAULT_PATH" \
    | rg '"type":"match"' \
    | head -50 \
    || {
      # rg exits 1 if no matches; we treat that as empty result, not error.
      [ "$?" -eq 1 ] && echo "[]" && return 0
    }
}

cmd_read() {
  local p="$1"
  [ -z "$p" ] && { echo "usage: vault read <path>" >&2; exit 2; }
  local full="$VAULT_PATH/$p"
  [ ! -f "$full" ] && { echo "ERROR: not found: $p" >&2; exit 1; }
  cat "$full"
}

cmd_write() {
  local p="$1"
  [ -z "$p" ] && { echo "usage: vault write <path>  (content from stdin)" >&2; exit 2; }
  local full="$VAULT_PATH/$p"
  mkdir -p "$(dirname "$full")"
  cat > "$full"
  echo "$p"
}

cmd_daily() {
  local arg="${1:-today}"
  local date
  case "$arg" in
    today) date=$(date +%Y-%m-%d) ;;
    yesterday) date=$(date -v-1d +%Y-%m-%d 2>/dev/null || date -d 'yesterday' +%Y-%m-%d) ;;
    *) date="$arg" ;;
  esac
  local p="daily-notes/${date}.md"
  local full="$VAULT_PATH/$p"
  if [ ! -f "$full" ]; then
    mkdir -p "$(dirname "$full")"
    {
      echo "---"
      echo "date: $date"
      echo "---"
      echo
      echo "# $date"
      echo
    } > "$full"
  fi
  echo "$p"
}

cmd_daily_append() {
  local text="$*"
  [ -z "$text" ] && { echo "usage: vault daily-append <text>" >&2; exit 2; }
  local p
  p=$(cmd_daily today)
  echo "$text" >> "$VAULT_PATH/$p"
  echo "appended to $p"
}

cmd_backlinks() {
  need rg
  local name="$1"
  [ -z "$name" ] && { echo "usage: vault backlinks <name>" >&2; exit 2; }
  # Match [[Name]] or [[Name|alias]] (escape regex metacharacters in name)
  local escaped
  escaped=$(printf '%s\n' "$name" | sed 's/[][\\.^$*+?(){}|]/\\&/g')
  rg -l "\[\[${escaped}(\|[^\]]*)?\]\]" "$VAULT_PATH" -t md 2>/dev/null \
    | sed "s|^${VAULT_PATH}/||" \
    || true
}

cmd_index() {
  # Walk all .md files. Group by top-level folder. For each, pull frontmatter
  # `title` if present, else file basename. Emit Karpathy-style index.md.
  local out="$VAULT_PATH/index.md"
  local tmpfile
  tmpfile=$(mktemp)

  {
    echo "# Vault index"
    echo
    echo "_Auto-generated by \`vault index\` — do not edit by hand._"
    echo "_Generated: $(date -Iseconds)_"
    echo
  } > "$tmpfile"

  # Build sorted list of top-level dirs that contain .md files
  local dirs
  dirs=$(find "$VAULT_PATH" -mindepth 1 -maxdepth 1 -type d \
          | sed "s|^${VAULT_PATH}/||" \
          | grep -vE '^\.' \
          | sort)

  # Loose files at vault root
  local root_files
  root_files=$(find "$VAULT_PATH" -maxdepth 1 -type f -name '*.md' \
                | sed "s|^${VAULT_PATH}/||" \
                | grep -v '^index\.md$' \
                | sort)
  if [ -n "$root_files" ]; then
    {
      echo "## /"
      echo
      while IFS= read -r f; do
        local title
        title=$(extract_title "$VAULT_PATH/$f")
        echo "- [[${f%.md}]] — ${title}"
      done <<< "$root_files"
      echo
    } >> "$tmpfile"
  fi

  # Each top-level dir
  while IFS= read -r d; do
    [ -z "$d" ] && continue
    local files
    files=$(find "$VAULT_PATH/$d" -type f -name '*.md' \
              | sed "s|^${VAULT_PATH}/||" \
              | sort)
    [ -z "$files" ] && continue
    {
      echo "## $d/"
      echo
      while IFS= read -r f; do
        local title
        title=$(extract_title "$VAULT_PATH/$f")
        echo "- [[${f%.md}]] — ${title}"
      done <<< "$files"
      echo
    } >> "$tmpfile"
  done <<< "$dirs"

  mv "$tmpfile" "$out"
  local count
  count=$(rg --files -t md "$VAULT_PATH" | wc -l | tr -d ' ')
  echo "wrote $out ($count files indexed)"
}

# Extract title: prefer frontmatter `title:`, fall back to first heading,
# fall back to basename without extension.
extract_title() {
  local file="$1"
  local in_fm=0
  local title=""
  local first_heading=""
  while IFS= read -r line || [ -n "$line" ]; do
    if [ "$in_fm" -eq 0 ] && [[ "$line" == "---" ]]; then
      in_fm=1
      continue
    fi
    if [ "$in_fm" -eq 1 ]; then
      if [[ "$line" == "---" ]]; then
        in_fm=2
        continue
      fi
      if [[ "$line" =~ ^title:[[:space:]]*(.+)$ ]]; then
        title="${BASH_REMATCH[1]}"
        # strip surrounding quotes
        title="${title%\"}"
        title="${title#\"}"
        title="${title%\'}"
        title="${title#\'}"
      fi
    elif [ "$in_fm" -eq 2 ] && [ -z "$first_heading" ]; then
      if [[ "$line" =~ ^#[[:space:]]+(.+)$ ]]; then
        first_heading="${BASH_REMATCH[1]}"
      fi
    fi
    [ "$in_fm" -eq 2 ] && [ -n "$first_heading" ] && break
  done < "$file"
  if [ -n "$title" ]; then echo "$title"
  elif [ -n "$first_heading" ]; then echo "$first_heading"
  else basename "$file" .md
  fi
}

cmd_ls() {
  local sub="${1:-}"
  local base="$VAULT_PATH"
  [ -n "$sub" ] && base="$VAULT_PATH/$sub"
  rg --files -t md "$base" 2>/dev/null \
    | sed "s|^${VAULT_PATH}/||" \
    | sort
}

# Append-only audit trail. Format: "<ISO-time> [<source>] <line>"
# Source defaults to "manual" but digest hooks pass "stop" / "precompact" / "session-end".
cmd_log() {
  local line="$*"
  [ -z "$line" ] && { echo "usage: vault log <line>" >&2; exit 2; }
  local source="manual"
  # Allow a leading [source] override: vault log "[stop] saved wiki/people/X.md"
  if [[ "$line" =~ ^\[([a-z-]+)\][[:space:]]+(.+)$ ]]; then
    source="${BASH_REMATCH[1]}"
    line="${BASH_REMATCH[2]}"
  fi
  printf '%s [%s] %s\n' "$(date -Iseconds 2>/dev/null || date +%Y-%m-%dT%H:%M:%S%z)" "$source" "$line" >> "$VAULT_PATH/log.md"
}

# Ensure the Karpathy-style layout exists. Idempotent — safe to call on
# every launch from start.sh.
cmd_scaffold() {
  mkdir -p "$VAULT_PATH/raw" \
           "$VAULT_PATH/daily-notes" \
           "$VAULT_PATH/wiki/people" \
           "$VAULT_PATH/wiki/concepts" \
           "$VAULT_PATH/wiki/projects" \
           "$VAULT_PATH/wiki/entities"
  # Create log.md if missing — empty file ok, hooks will append.
  [ -f "$VAULT_PATH/log.md" ] || cat > "$VAULT_PATH/log.md" <<EOF
# Vault audit log

Append-only. Each line: \`<ISO-time> [<source>] <summary>\`. Sources:

- \`manual\` — user / agent direct write
- \`stop\` — Stop-hook digest (after each turn)
- \`precompact\` — PreCompact-hook digest (before context compaction)
- \`session-end\` — SessionEnd-hook digest (final pass)

EOF
  # Create initial index.md if missing.
  [ -f "$VAULT_PATH/index.md" ] || cmd_index >/dev/null
  echo "✔ vault scaffolded at $VAULT_PATH"
}

case "${1:-}" in
  search) shift; cmd_search "$@" ;;
  read) shift; cmd_read "$@" ;;
  write) shift; cmd_write "$@" ;;
  daily) shift; cmd_daily "$@" ;;
  daily-append) shift; cmd_daily_append "$@" ;;
  backlinks) shift; cmd_backlinks "$@" ;;
  index) cmd_index ;;
  ls) shift; cmd_ls "$@" ;;
  log) shift; cmd_log "$@" ;;
  scaffold) cmd_scaffold ;;
  ""|--help|-h)
    sed -n '/^# bin\/vault/,/^$/p' "$0" | sed 's/^# \?//'
    ;;
  *)
    echo "unknown command: $1" >&2
    echo "run 'vault --help'" >&2
    exit 2
    ;;
esac
