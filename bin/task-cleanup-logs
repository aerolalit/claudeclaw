#!/bin/bash
# bin/task-cleanup-logs — prune old per-run logs, keeping the last N per task.
# Safe to call at the end of any task script, or as a standalone cron job.
#
# Usage:
#   bin/task-cleanup-logs [keep_count]   (default: 50)

set -euo pipefail

KEEP=${1:-50}
PROJECT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
LOGS_DIR="$PROJECT_DIR/.tasks/logs"

[ -d "$LOGS_DIR" ] || exit 0

for task_dir in "$LOGS_DIR"/*/; do
  [ -d "$task_dir" ] || continue
  task=$(basename "$task_dir")
  count=$(find "$task_dir" -maxdepth 1 -name "*.log" | wc -l)
  if [ "$count" -gt "$KEEP" ]; then
    to_delete=$(( count - KEEP ))
    find "$task_dir" -maxdepth 1 -name "*.log" | sort | head -n "$to_delete" | xargs rm -f
    echo "[$task] pruned $to_delete old logs (kept $KEEP)"
  fi
done
