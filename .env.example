# Repo-local environment overrides for the Telegram plugin.
# Copy to `.env` and fill in. The .env file is gitignored — never commit it.
#
# These values are loaded by start.sh and exported into the Claude Code
# process environment. The Telegram plugin reads process.env first, then
# falls back to ~/.claude/channels/telegram/.env. So a value set here wins.
#
# Get a bot token by DMing @BotFather on Telegram and running /newbot.

TELEGRAM_BOT_TOKEN=

# Optional. "static" = no pairing UI, allowlist-only. Default = pairing flow.
# TELEGRAM_ACCESS_MODE=static

# --- Claude Code auth (only needed on headless servers / Pi) ---
# If running on a desktop/laptop, just use `claude login` instead.
# If running on a server with no browser:
#   1. On a machine WITH a browser, run: claude setup-token
#   2. Paste the printed token below.
# Requires a Claude Pro / Max / Team subscription. Token valid ~1 year.
# CLAUDE_CODE_OAUTH_TOKEN=
