# STRICT ALLOWLIST: ignore everything by default; only the paths explicitly
# un-ignored below are tracked. Add new tracked paths here.
#
# Rules:
#   * "!" un-ignores. Both the parent dirs and the file/glob need to be unignored.
#   * Subdirs of an unignored dir are NOT auto-included — list "!dir/" then "!dir/**".
#   * For nested paths, un-ignore each level: "!a/", "!a/b/", "!a/b/c"
#
# Verify with: git status (untracked files mean you need to add them here).

# --- Ignore everything ---
*

# --- Allow git's own metadata ---
!.gitignore

# --- Top-level files ---
!CLAUDE.md
!CHANGELOG.md
!CONTRIBUTING.md
!LICENSE
!README.md
!SECURITY.md
!install.sh
!start.sh
!.env.example

# --- vault tooling (CLI, gitignored vault content) ---
!bin/
!bin/**
# vault/ is intentionally NOT un-ignored: it holds user content (markdown
# notes), populated either at the repo root or via VAULT_PATH=/elsewhere.

# --- Claude Code config ---
!.claude/
.claude/*
!.claude/settings.json
!.claude/hooks/
!.claude/hooks/**

# --- Plugin marketplace manifest ---
!.claude-plugin/
!.claude-plugin/**

# --- Forked Telegram plugin ---
!plugins/
plugins/*
!plugins/telegram/
plugins/telegram/*
!plugins/telegram/.claude-plugin/
!plugins/telegram/.claude-plugin/**
!plugins/telegram/.mcp.json
!plugins/telegram/.npmrc
!plugins/telegram/ACCESS.md
!plugins/telegram/LICENSE
!plugins/telegram/NOTICE
!plugins/telegram/README.md
!plugins/telegram/package-lock.json
!plugins/telegram/package.json
!plugins/telegram/server.ts
!plugins/telegram/tsconfig.json
!plugins/telegram/skills/
!plugins/telegram/skills/**

# --- Profile templates ---
!templates/
!templates/**

# --- Scheduled task scripts (runtime logs are gitignored) ---
!.tasks/
.tasks/*
!.tasks/scripts/
!.tasks/scripts/**
# personal scripts, not for OSS
.tasks/scripts/payslip-monthly.sh

# --- Documentation + assets (README GIFs, screenshots, etc.) ---
!docs/
!docs/**
!assets/
!assets/**
