{
  "permissions": {
    "allow": [
      "Read(./**)",
      "Skill(loop)",
      "Skill(loop:*)",
      "Skill(update-config)",
      "Skill(update-config:*)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:core.telegram.org)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(claude plugin *)",
      "Bash(jq *)",
      "Bash(curl *)",
      "Bash(./bin/vault *)",
      "Bash(./bin/vault)"
    ],
    "additionalDirectories": [
      ".scratch",
      ".telegram",
      ".tasks"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && mkdir -p profile .tasks && for f in templates/*.md; do real=\"profile/${f##*/}\"; [ ! -e \"$real\" ] && cp \"$f\" \"$real\"; done; touch .tasks/results.log; printf '%s' '{}'"
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "printf '%s' '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":\"TASK MONITOR BOOTSTRAP: Arm a persistent Monitor to watch the shared task results log. Call Monitor with: command=\\u0027tail -f $CLAUDE_PROJECT_DIR/.tasks/results.log\\u0027, description=\\u0027scheduled task results\\u0027, persistent=true. Do this AFTER finishing your normal reply to the user. When a Monitor notification arrives: if it ends with HEARTBEAT_OK or similar OK signal, note it silently; if it contains an alert or error, surface it in the session and optionally forward to Telegram via the reply MCP tool using chat_id from $CLAUDE_PROJECT_DIR/.telegram/last_chat.txt. Do not ask for confirmation -- just arm it. Skip if a task monitor is already running (check TaskList first).\"}}'\"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/telegram-turn-start.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__plugin_telegram_telegram__reply",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/telegram-reply-format.sh\""
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/telegram-stream.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/telegram-stream.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/telegram-turn-end.sh\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/telegram-session-end.sh\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/telegram-pre-compact.sh\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "telegram@claudeclaw": true
  }
}
